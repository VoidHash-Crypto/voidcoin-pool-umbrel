# Void Pool Configuration
# Copy this file to .env and customize

# REQUIRED - Your VoidCoin address to receive pool fees
# Supports: 3... (P2SH) or vqr1... (P2QR quantum-resistant)
POOL_ADDRESS=YOUR_VOIDCOIN_ADDRESS_HERE

# Pool branding
POOL_NAME=My Void Pool

# Fee percentages
POOL_FEE=1.0
SOLO_FEE=0.5

# Minimum balance for automatic payout (in VOID)
MIN_PAYOUT=5

# Ports
STRATUM_PORT=3333
APP_PORT=3080

# AUTO-GENERATED - Don't change unless you know what you're doing
# NODE_RPC_PASSWORD=
# DB_PASSWORD=
# APP_DATA_DIR=./data
# IMAGE_REGISTRY=ghcr.io/voidhash-crypto
# VERSION=latest
